{
  "manifest_version": 3,
  "name": "eBay Profit Calculator",
  "version": "1.4.2",
  "description": "Instantly calculate net profit, eBay fees, PayPal/Stripe fees, shipping costs, and ROI on any eBay listing page. Built for dropshippers and resellers.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.ebay.com/*",
    "https://ebay.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.ebay.com/itm/*", "https://www.ebay.com/sch/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
